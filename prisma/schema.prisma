generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DailyHealthEntry {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  weightKg       Float?
  steps          Int?
  caloriesEaten  Int?
  caloriesBurned Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
