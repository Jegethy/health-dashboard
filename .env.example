DATABASE_URL="file:./dev.db"

# Fitbit OAuth for local personal use.
FITBIT_CLIENT_ID="your-fitbit-client-id"
FITBIT_CLIENT_SECRET="your-fitbit-client-secret"
FITBIT_REDIRECT_URI="http://127.0.0.1:3000/api/integrations/fitbit/callback"
FITBIT_SCOPES="activity weight nutrition profile"

# Use a long random value. Example generation:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FITBIT_TOKEN_ENCRYPTION_KEY="replace-with-a-random-local-key"
